<Window x:Class="VisualMetronome.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisualMetronome"
        mc:Ignorable="d"
        Title="Franco-nome" 
        Height="600" 
        Width="800"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        Background="#FF2C3E50">
    
    <Grid x:Name="MainCanvas">
        <!-- Main content area that will flash -->
        <Grid.Background>
            <SolidColorBrush x:Name="BackgroundBrush" Color="#FF2C3E50"/>
        </Grid.Background>
        
        <!-- Control panel at the top -->
        <StackPanel Orientation="Horizontal" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top" 
                   Margin="20"
                   Background="#AA000000"
                   Height="80">
            
            <TextBlock Text="BPM:" 
                      FontSize="24" 
                      Foreground="White" 
                      VerticalAlignment="Center" 
                      Margin="20,0,10,0"/>
            
            <TextBox x:Name="BpmTextBox" 
                    Text="120" 
                    FontSize="24" 
                    Width="100" 
                    Height="40"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"/>
            
            <Button x:Name="FullScreenButton" 
                   Content="Toggle Fullscreen (ESC)" 
                   FontSize="16" 
                   Margin="20,0,10,0"
                   Height="40"
                   Padding="10,5"
                   Click="FullScreenButton_Click"/>
            
            <TextBlock x:Name="StatusText" 
                      Text="Ready" 
                      FontSize="18" 
                      Foreground="LightGray" 
                      VerticalAlignment="Center" 
                      Margin="20,0,0,0"/>
        </StackPanel>
        
        <!-- Central display area -->
        <StackPanel VerticalAlignment="Center" 
                   HorizontalAlignment="Center">
            
            <TextBlock x:Name="BpmDisplay" 
                      Text="120 BPM" 
                      FontSize="72" 
                      Foreground="White" 
                      HorizontalAlignment="Center"
                      FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="3" BlurRadius="5" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <TextBlock Text="Visual Metronome" 
                      FontSize="24" 
                      Foreground="LightGray" 
                      HorizontalAlignment="Center"
                      Margin="0,20,0,0"/>
        </StackPanel>
        
        <!-- Instructions at the bottom -->
        <TextBlock Text="Press ESC to toggle fullscreen | Enter BPM above to start" 
                  FontSize="16" 
                  Foreground="LightGray" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Bottom" 
                  Margin="20"/>
    </Grid>
</Window>
