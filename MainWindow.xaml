<Window x:Class="VisualMetronome.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisualMetronome"
        mc:Ignorable="d"
        Title="Franco-nome" 
        Height="600" 
        Width="800"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        Background="#FF2C3E50">
    
    <Grid x:Name="MainCanvas">
        <!-- Main content area that will flash -->
        <Grid.Background>
            <SolidColorBrush x:Name="BackgroundBrush" Color="#FF2C3E50"/>
        </Grid.Background>
        
        <!-- Control panel at the top -->
        <StackPanel Orientation="Horizontal" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top" 
                   Margin="20"
                   Background="#AA000000">
            
            <TextBlock Text="BPM:" 
                      FontSize="24" 
                      Foreground="White" 
                      VerticalAlignment="Center" 
                      Margin="20,0,10,0"/>
            
            <TextBox x:Name="BpmTextBox" 
                    Text="120" 
                    FontSize="24" 
                    Width="100" 
                    Height="40"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"/>
            
            <Button x:Name="FullScreenButton" 
                   Content="Toggle Fullscreen (ESC)" 
                   FontSize="16" 
                   Margin="20,0,10,0"
                   Height="40"
                   Padding="10,5"
                   Click="FullScreenButton_Click"/>
            
            <TextBlock x:Name="StatusText" 
                      Text="Ready" 
                      FontSize="18" 
                      Foreground="LightGray" 
                      VerticalAlignment="Center" 
                      Margin="20,0,0,0"/>
        </StackPanel>
        
        <!-- Spotify Control Panel -->
        <StackPanel Orientation="Vertical" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" 
                   Margin="20,120,0,0"
                   Background="#AA000000"
                   Visibility="Visible">
            
            <TextBlock Text="Spotify Integration" 
                      FontSize="20" 
                      Foreground="White" 
                      Margin="15,10,15,10"
                      FontWeight="Bold"/>
            
            <Button x:Name="SpotifyLoginButton" 
                   Content="Connect to Spotify" 
                   FontSize="16" 
                   Margin="15,5,15,5"
                   Height="40"
                   Click="SpotifyLoginButton_Click"/>
            
            <ComboBox x:Name="PlaylistComboBox" 
                     FontSize="14" 
                     Margin="15,5,15,5"
                     Height="35"
                     IsEnabled="False"
                     SelectionChanged="PlaylistComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Center" 
                       Margin="15,10,15,5">
                
                <Button x:Name="PreviousButton" 
                       Content="◀ Previous" 
                       FontSize="24" 
                       Width="160"
                       Height="60"
                       Margin="0,0,15,0"
                       IsEnabled="False"
                       Click="PreviousButton_Click"/>
                
                <Button x:Name="StartButton" 
                       Content="▶ Start" 
                       FontSize="24" 
                       Width="160"
                       Height="60"
                       Margin="0,0,15,0"
                       IsEnabled="False"
                       Click="StartButton_Click"/>
                
                <Button x:Name="NextButton" 
                       Content="Next ▶" 
                       FontSize="24" 
                       Width="160"
                       Height="60"
                       IsEnabled="False"
                       Click="NextButton_Click"/>
            </StackPanel>
            
            <Button x:Name="CacheSetlistButton" 
                   Content="⬇ Cache Setlist BPM (offline prep)" 
                   FontSize="14" 
                   Margin="15,5,15,5"
                   Height="40"
                   IsEnabled="False"
                   Click="CacheSetlistButton_Click"/>
            
            <TextBlock x:Name="CacheProgressText" 
                      Text="" 
                      FontSize="12" 
                      Foreground="#FF7FD37F" 
                      Margin="15,0,15,5"
                      TextWrapping="Wrap"/>
            
            <TextBlock x:Name="CurrentTrackText" 
                      Text="No track loaded" 
                      FontSize="12" 
                      Foreground="LightGray" 
                      Margin="15,10,15,10"
                      TextWrapping="Wrap"/>
        </StackPanel>
        
        <!-- Central display area -->
        <StackPanel VerticalAlignment="Center" 
                   HorizontalAlignment="Center">
            
            <TextBlock x:Name="SongTitleDisplay" 
                      Text="" 
                      FontSize="72" 
                      Foreground="White" 
                      HorizontalAlignment="Center"
                      FontWeight="Bold"
                      TextWrapping="Wrap"
                      TextAlignment="Center"
                      MaxWidth="1200"
                      Margin="20,0,20,20">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="3" BlurRadius="5" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <TextBlock x:Name="BpmDisplay" 
                      Text="120 BPM" 
                      FontSize="72" 
                      Foreground="White" 
                      HorizontalAlignment="Center"
                      FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="3" BlurRadius="5" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
        
        <!-- Instructions at the bottom -->
        <TextBlock Text="Press ESC to toggle fullscreen | Enter BPM above to start" 
                  FontSize="16" 
                  Foreground="LightGray" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Bottom" 
                  Margin="20"/>
    </Grid>
</Window>
